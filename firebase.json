{
  "hosting": {
    "public": ".",
    "ignore": [
      ".git",
      ".github",
      "firebase.json",
      ".firebaserc",
      "CLAUDE.md"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "robots.txt",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      },
      {
        "source": "sitemap.xml",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          },
          {
            "key": "Content-Type",
            "value": "application/xml"
          }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
